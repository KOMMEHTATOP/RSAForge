<ui:FluentWindow x:Class="RSAForge.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="RSAForge" 
        Height="780" Width="550"
        MinWidth="500" MinHeight="700"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
        </Grid.RowDefinitions>

        <ui:TitleBar Title="RSAForge - Key Generator" Grid.Row="0">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="ShieldLock24"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="20,5,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="*"/>    
                <RowDefinition Height="*"/>    
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/> 
            </Grid.RowDefinitions>
            
            <Border Grid.Row="0" Background="{DynamicResource ControlFillColorDefaultBrush}" 
                    CornerRadius="8" Padding="15" Margin="0,0,0,15"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="ФОРМАТ" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <ComboBox HorizontalAlignment="Stretch"
                                  Text="{Binding SelectedFormat, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBoxItem Content="PKCS#8 (Modern)"/>
                            <ComboBoxItem Content="PKCS#1 (Old)"/>
                            <ComboBoxItem Content="XML"/>
                            <ComboBoxItem Content="SSH-RSA"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="ДЛИНА КЛЮЧА" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <ComboBox HorizontalAlignment="Stretch" 
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding SelectedKeySize}">
                            <ComboBoxItem Content="2048 bit" Tag="2048"/>
                            <ComboBoxItem Content="3072 bit" Tag="3072"/>
                            <ComboBoxItem Content="4096 bit" Tag="4096"/>
                        </ComboBox>
                    </StackPanel>

                    <ui:Button Grid.Column="2" Content="Сгенерировать" 
                               Command="{Binding GenerateCommand}"
                               Appearance="Primary" VerticalAlignment="Bottom" Padding="15,7"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                    <TextBlock Text="ПУБЛИЧНЫЙ КЛЮЧ" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <CheckBox Content="Без заголовков" IsChecked="{Binding PublicStripHeaders}" Margin="15,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                    <CheckBox Content="В одну строку" IsChecked="{Binding PublicSingleLine}" Margin="10,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Grid Grid.Row="1">
                    <ui:TextBox IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                Text="{Binding DisplayPublicKey, Mode=OneWay}"
                                FontFamily="Cascadia Code, Consolas" VerticalContentAlignment="Top"
                                Padding="10,10,45,10"
                                PlaceholderText="Здесь будет сгенерированный публичный ключ..."/>
                    
                    <ui:Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                               Command="{Binding CopyCommand}" CommandParameter="Public"
                               Appearance="Transparent" Padding="8" Margin="5"
                               ToolTip="Копировать" Icon="{ui:SymbolIcon Symbol=Copy24}"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                    <TextBlock Text="ПРИВАТНЫЙ КЛЮЧ" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <CheckBox Content="Без заголовков" IsChecked="{Binding PrivateStripHeaders}" Margin="15,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                    <CheckBox Content="В одну строку" IsChecked="{Binding PrivateSingleLine}" Margin="10,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Grid Grid.Row="1">
                    <ui:TextBox IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                Text="{Binding DisplayPrivateKey, Mode=OneWay}"
                                FontFamily="Cascadia Code, Consolas" VerticalContentAlignment="Top"
                                Padding="10,10,45,10"
                                PlaceholderText="Здесь будет сгенерированный приватный ключ..."/>
                    
                    <ui:Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                               Command="{Binding CopyCommand}" CommandParameter="Private"
                               Appearance="Transparent" Padding="8" Margin="5"
                               ToolTip="Копировать" Icon="{ui:SymbolIcon Symbol=Copy24}"/>
                </Grid>
            </Grid>
            
            <ui:Button Grid.Row="3" 
                       Command="{Binding SaveCommand}"
                       HorizontalAlignment="Right" 
                       VerticalAlignment="Bottom"
                       Appearance="Secondary"
                       Margin="0,0,0,15"
                       Padding="15,5"
                       Icon="{ui:SymbolIcon Symbol=Save24}"
                       Content="Сохранить пару"/>

            <Border Grid.Row="4" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="0,1,0,0" Padding="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="ТЕСТ ВАЛИДАЦИИ" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10" 
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Text="{Binding TestPhrase, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="Введите текст для проверки..." Margin="0,0,10,0"/>
                        <ui:Button Grid.Column="1" Command="{Binding ValidateCommand}"
                                   Content="Проверить пару" Appearance="Secondary" Padding="15,5"/>
                    </Grid>
                    <ui:TextBlock Text="{Binding ValidationResult}" Margin="0,10,0,0" 
                                  FontWeight="Medium" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>